# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# 1. dependencies (ไฟล์ไลบรารีขนาดใหญ่)
/node_modules

# 2. next.js build output & cache (โฟลเดอร์แคชการทำงาน)
/.next/
/out/
/build

# 3. debug logs (บันทึกข้อผิดพลาดในการติดตั้ง)
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# 4. vercel configuration (การตั้งค่า Vercel)
.vercel

# 5. typescript configuration
*.tsbuildinfo
next-env.d.ts

# 6. lockfile (ตามความต้องการที่ไม่อยาก push)
pnpm-lock.yaml

# 7. local backups & agent tools (โฟลเดอร์สำรองข้อมูลและโฟลเดอร์ของ AI)
/backend-java-backup
.agents/

# 8. CRITICAL: Security & Privacy (ความปลอดภัยและการป้องกันข้อมูลรั่วไหล)
# ------------------------------------------------------------
# ละเว้นไฟล์เก็บรหัสผ่านฐานข้อมูล Supabase และค่า Config ลับทั้งหมด
.env
.env.local
.env.development.local
.env.production.local
.env.test.local
.env*.local

# ละเว้นรูปภาพสลิปโอนเงินส่วนตัวของเพื่อนๆ ที่ถูกอัปโหลดเข้ามาใช้งานจริง
# เพื่อป้องกันไม่ให้ข้อมูลทางการเงินรั่วไหลขึ้นไปบน GitHub สาธารณะ
/public/uploads/
# ------------------------------------------------------------