datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Bill {
  id                BigInt     @id @default(autoincrement()) @map("ID")
  title             String     @db.VarChar(120) @map("TITLE")
  payeeName         String?    @map("PAYEE_NAME") @db.VarChar(120)
  payeePromptPayId  String     @map("PAYEE_PROMPTPAY_ID") @db.VarChar(30)
  currency          String     @default("THB") @db.VarChar(8) @map("CURRENCY")
  publicSlug        String     @unique @map("PUBLIC_SLUG") @db.VarChar(64)
  createdAt         DateTime   @default(now()) @map("CREATED_AT") @db.Timestamptz
  closeAt           DateTime?  @map("CLOSE_AT") @db.Timestamptz
  items             BillItem[]

  @@index([publicSlug], map: "idx_bills_slug")
  @@map("BILLS")
}

model BillItem {
  id            BigInt    @id @default(autoincrement()) @map("ID")
  billId        BigInt    @map("BILL_ID")
  displayName   String    @map("DISPLAY_NAME") @db.VarChar(80)
  amount        Decimal   @db.Decimal(12, 2) @map("AMOUNT")
  status        String    @default("UNPAID") @db.VarChar(16) @map("STATUS")
  referenceCode String    @map("REFERENCE_CODE") @db.VarChar(64)
  paidAt        DateTime? @map("PAID_AT") @db.Timestamptz
  bill          Bill      @relation(fields: [billId], references: [id], onDelete: Cascade)
  payments      Payment[]

  @@index([billId], map: "idx_items_bill")
  @@map("BILL_ITEMS")
}

model Payment {
  id             BigInt    @id @default(autoincrement()) @map("ID")
  billItemId     BigInt    @map("BILL_ITEM_ID")
  slipUrl        String    @map("SLIP_URL")
  bankRef        String?   @map("BANK_REF") @db.VarChar(64)
  detectedAmount Decimal?  @map("DETECTED_AMOUNT") @db.Decimal(12, 2)
  detectedTime   DateTime? @map("DETECTED_TIME") @db.Timestamptz
  verifyScore    Int       @default(0) @map("VERIFY_SCORE")
  status         String    @default("SUBMITTED") @db.VarChar(16) @map("STATUS")
  createdAt      DateTime  @default(now()) @map("CREATED_AT") @db.Timestamptz
  billItem       BillItem  @relation(fields: [billItemId], references: [id], onDelete: Cascade)

  @@index([billItemId], map: "idx_payments_item")
  @@map("PAYMENTS")
}
